{
	"name": "@bgtendtofree/pi-patchcraft",
	"version": "0.1.0",
	"description": "Transactional Codex-style apply_patch tool for Pi",
	"type": "module",
	"license": "MIT",
	"homepage": "https://github.com/bgtendtofree/pi-patchcraft#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bgtendtofree/pi-patchcraft.git"
	},
	"bugs": {
		"url": "https://github.com/bgtendtofree/pi-patchcraft/issues"
	},
	"packageManager": "bun@1.3.14",
	"engines": {
		"node": ">=24"
	},
	"keywords": [
		"pi-package",
		"pi",
		"pi-extension",
		"apply-patch",
		"codex",
		"transactional",
		"progressive-tools",
		"typescript"
	],
	"files": [
		"src",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"scripts": {
		"typecheck": "bunx --bun tsc -p tsconfig.test.json",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"fix": "biome check --write .",
		"quality": "biome ci .",
		"test": "node --test",
		"test:watch": "node --test --watch",
		"test:coverage": "rm -rf coverage && mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-include=\"src/**/*.ts\" --test-coverage-exclude=\"test/**/*.ts\" --test-coverage-lines=80 --test-coverage-functions=75 --test-coverage-branches=70 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
		"smoke": "pi --offline --no-extensions -e . --list-models",
		"smoke:package": "node scripts/smoke-package.mjs",
		"package:check": "npm pack --dry-run",
		"validate": "bun run quality && bun run typecheck && bun run test",
		"ci": "bun run quality && bun run typecheck && bun run test:coverage && bun run smoke && bun run package:check && bun run smoke:package"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4",
		"@earendil-works/pi-ai": "0.80.10",
		"@earendil-works/pi-coding-agent": "0.80.10",
		"@earendil-works/pi-tui": "0.80.10",
		"@types/node": "^24.0.0",
		"typebox": "1.1.38",
		"typescript": "7.0.2"
	}
}
